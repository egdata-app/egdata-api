{
  "$schema": "https://biomejs.dev/schemas/2.3.15/schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space"
  },
  "files": {
    "includes": [
      "**",
      "!**/tests/__snapshots__",
      "!apps/docs/.source",
      "!apps/docs/.tanstack",
      "!apps/docs/.wrangler",
      "!apps/docs/dist",
      "!apps/docs/routeTree.gen.ts"
    ]
  }
}
