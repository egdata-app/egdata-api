{
  "version": "0.1.0-alpha.0",
  "packageManager": "pnpm@11.0.0",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "rslib build",
    "start": "node --enable-source-maps --env-file=.env dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/utils tests/diff.test.ts tests/search-route.test.ts tests/items-route.test.ts tests/offers-localization-route.test.ts",
    "test:routes": "vitest run tests/route-coverage.test.ts",
    "test:capture": "tsx tests/capture.ts",
    "typecheck": "tsc --noEmit",
    "openapi:generate": "tsx scripts/generate-openapi.ts",
    "openapi:check": "tsx scripts/check-openapi.ts",
    "docs:dev": "pnpm --filter @egdata/docs dev",
    "docs:build": "pnpm --filter @egdata/docs build",
    "docs:check": "pnpm openapi:check && pnpm --filter @egdata/docs typecheck",
    "docs:generate": "pnpm openapi:generate && pnpm --filter @egdata/docs generate",
    "readme:check": "node scripts/check-readme-commands.mjs",
    "release:check": "node scripts/check-release-policy.mjs"
  },
  "type": "module",
